rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function identityUnchanged() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.displayName == resource.data.displayName;
    }

    // Only partnerName + coupleId may be written when linking someone else
    function isPartnerLinkUpdate() {
      return identityUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['partnerName', 'coupleId']);
    }

    match /users/{nameLower} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.displayName.matches('^[A-Za-z0-9]{3,20}$')
        && nameLower == request.resource.data.displayName.lower();

      // Owner can update their profile; anyone signed in can set partner link fields only
      allow update: if signedIn()
        && identityUnchanged()
        && (isOwner() || isPartnerLinkUpdate());

      allow delete: if false;
    }

    match /couples/{coupleId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2;
      allow update: if false;
      allow delete: if false;

      match /swipes/{swipeId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.resource.data.userName is string
          && request.resource.data.titleId is string
          && request.resource.data.decision in ['yup', 'nope', 'gottaSeeIt']
          && swipeId == request.resource.data.titleId + '_' + request.resource.data.userName.lower();
        allow delete: if false;
      }

      match /matches/{titleId} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.resource.data.titleId == titleId
          && request.resource.data.reason in ['mutual', 'gottaSeeIt'];
        allow delete: if false;
      }
    }
  }
}
